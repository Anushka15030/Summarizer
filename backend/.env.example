# Copy this file to .env (for local development) and fill in your own key.
# Get a free Gemini API key at https://aistudio.google.com/apikey
#
# In production (Render), set these as real environment variables in the
# service's dashboard instead of committing a .env file.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-2.5-flash if not set.
GEMINI_MODEL=gemini-2.5-flash
